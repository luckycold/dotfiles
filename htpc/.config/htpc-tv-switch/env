# Fedora/Nobara HTPC display target.
# Current setup exposes the TCL TV as DP-3 in Plasma/KScreen.
SWITCH_TO_TV_OUTPUT="DP-3"
SWITCH_TO_TV_MODE="preferred"
SWITCH_TO_TV_SCALE="1"
SWITCH_TO_TV_DISPLAY_BACKEND="none"

# In gamemode, only ask the TV to wake/switch to the HTPC input over HDMI-CEC.
# Do not try to control the local display layout from this service.

# Use HDMI-CEC to ask the TV to wake/switch to this PC input. Requires
# /dev/cec0 access from the active session.
HTPC_TV_CEC_ENABLE="1"
HTPC_TV_CEC_DEVICE="/dev/cec0"
HTPC_TV_CEC_OSD_NAME="HTPC"
HTPC_TV_CEC_LOGICAL_ADDRESS="4"
HTPC_TV_CEC_TIMEOUT="5"
HTPC_TV_CEC_WAKE_DELAY="1"

# Steam Controller input device name matcher. This is an extended regular
# expression matched against /sys/class/input/event*/device/name.
STEAM_CONTROLLER_PATTERN="Steam Controller|Valve Software Steam Controller|Valve Steam Controller"

# Delay after input hotplug before checking devices, giving udev time to settle.
STEAM_CONTROLLER_TV_SWITCH_DEBOUNCE="0"
STEAM_CONTROLLER_TV_SWITCH_RESUME_DELAY="0"
STEAM_CONTROLLER_TV_SWITCH_RESUME_CEC_WAKE_DELAY="1"
STEAM_CONTROLLER_TV_SWITCH_COOLDOWN="20"
STEAM_CONTROLLER_TV_SWITCH_ON_STARTUP="0"
