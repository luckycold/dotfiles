#!/usr/bin/env bash
set -euo pipefail

controller_pattern="${STEAM_CONTROLLER_PATTERN:-Steam Controller|Valve Software Steam Controller|Valve Steam Controller}"
debounce_seconds="${STEAM_CONTROLLER_TV_SWITCH_DEBOUNCE:-3}"
resume_delay_seconds="${STEAM_CONTROLLER_TV_SWITCH_RESUME_DELAY:-0}"
resume_cec_wake_delay="${STEAM_CONTROLLER_TV_SWITCH_RESUME_CEC_WAKE_DELAY:-1}"
cooldown_seconds="${STEAM_CONTROLLER_TV_SWITCH_COOLDOWN:-10}"
switch_to_tv_command="${SWITCH_TO_TV_COMMAND:-$HOME/.local/bin/switch-to-tv}"
lock_file="${STEAM_CONTROLLER_TV_SWITCH_LOCK:-${XDG_RUNTIME_DIR:-/tmp}/steam-controller-tv-switch.lock}"
last_run_file="${STEAM_CONTROLLER_TV_SWITCH_LAST_RUN:-${XDG_RUNTIME_DIR:-/tmp}/steam-controller-tv-switch.last-run}"
child_pids=()

log() {
  printf 'steam-controller-tv-switch-monitor: %s\n' "$*"
}

die() {
  log "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

require_executable() {
  [[ -x "$1" ]] || die "missing required executable: $1"
}

steam_controller_present() {
  local name
  local name_file

  for name_file in /sys/class/input/event*/device/name; do
    [[ -r "$name_file" ]] || continue
    name="$(<"$name_file")"

    if [[ "$name" =~ $controller_pattern ]]; then
      return 0
    fi
  done

  return 1
}

run_switch_command() {
  local cec_wake_delay="${1:-}"

  if [[ -n "$cec_wake_delay" ]]; then
    flock -n "$lock_file" env HTPC_TV_CEC_WAKE_DELAY="$cec_wake_delay" "$switch_to_tv_command"
  else
    flock -n "$lock_file" "$switch_to_tv_command"
  fi
}

switch_if_present() {
  local cec_wake_delay="${1:-}"
  local force="${2:-0}"
  local trigger="${3:-event}"
  local last_run
  local now

  if steam_controller_present; then
    now="$(date +%s)"
    last_run="0"
    [[ -r "$last_run_file" ]] && last_run="$(<"$last_run_file")"

    if [[ "$force" != "1" ]] && (( now - last_run < cooldown_seconds )); then
      return 0
    fi

    log "Steam Controller detected via $trigger; switching to TV"
    printf '%s\n' "$now" >"$last_run_file"
    run_switch_command "$cec_wake_delay"
  fi
}

watch_input_events() {
  udevadm monitor --udev --subsystem-match=input | while IFS= read -r line; do
    case "$line" in
      *add*|*bind*)
        sleep "$debounce_seconds"
        switch_if_present "" 0 input-hotplug
        ;;
    esac
  done
}

watch_resume_events() {
  dbus-monitor --system "type='signal',interface='org.freedesktop.login1.Manager',member='PrepareForSleep'" | while IFS= read -r line; do
    case "$line" in
      *"boolean false"*)
        sleep "$resume_delay_seconds"
        switch_if_present "$resume_cec_wake_delay" 1 resume
        ;;
    esac
  done
}

cleanup() {
  local pid

  for pid in "${child_pids[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
}

require_executable "$switch_to_tv_command"
require_command udevadm
require_command dbus-monitor
require_command flock

switch_if_present
log "watching input hotplug and resume events"
trap cleanup EXIT INT TERM
watch_input_events & child_pids+=("$!")
watch_resume_events & child_pids+=("$!")
wait -n "${child_pids[@]}"
