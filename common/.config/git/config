# See https://git-scm.com/docs/git-config

[alias]
	co = checkout
	br = branch
	ci = "!f() { \
		if [ \"$(git config --type=bool --get commit.gpgsign 2>/dev/null)\" != \"true\" ]; then \
			exec git commit \"$@\"; \
		fi; \
		signing_key_blob=$(git config --get user.signingkey 2>/dev/null | awk 'NF>=2 && $1 ~ /^ssh-/ {print $2}'); \
		if [ -z \"$signing_key_blob\" ]; then \
			exec git commit \"$@\"; \
		fi; \
		if ssh-add -L 2>/dev/null | awk 'NF>=2 && $1 ~ /^ssh-/ {print $2}' | grep -Fxq \"$signing_key_blob\"; then \
			exec git commit \"$@\"; \
		fi; \
		echo 'warning: ssh signing key missing in ssh-agent; creating unsigned commit' >&2; \
		if command -v notify-send >/dev/null 2>&1; then \
			notify-send 'Git signing fallback' 'SSH signing key missing in ssh-agent; commit created unsigned.' >/dev/null 2>&1 || true; \
		fi; \
		exec git commit --no-gpg-sign \"$@\"; \
	}; f"
	st = status
[core]
	editor = nvim
[init]
	defaultBranch = master
[pull]
	rebase = true 			 # Rebase (instead of merge) on pull
[push]
	autoSetupRemote = true   # Automatically set upstream branch on push
[diff]
	algorithm = histogram    # Clearer diffs on moved/edited lines
	colorMoved = plain       # Highlight moved blocks in diffs
	mnemonicPrefix = true    # More intuitive refs in diff output
[commit]
	verbose = true           # Include diff comment in commit message template
	gpgsign = true
[column]
	ui = auto 			     # Output in columns when possible
[branch]
	sort = -committerdate    # Sort branches by most recent commit first
[tag]
	sort = -version:refname  # Sort version numbers as you would expect
[rerere]
	enabled = true           # Record and reuse conflict resolutions
	autoupdate = true        # Apply stored conflict resolutions automatically
