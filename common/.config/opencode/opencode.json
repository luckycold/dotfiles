        "npx",
        "-y",
        "czottmann/kagi-ken-mcp"
      ],
      "enabled": true
    },
    "clickup": {
      "type": "remote",
      "url": "https://mcp.clickup.com/mcp",
      "enabled": false
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/linear}"
      },
      "oauth": false,
      "enabled": false
    },
    "gitlab": {
      "type": "remote",
      "url": "https://gitlab.com/api/v4/mcp",
      "enabled": true
    },
    "brokkr-dev": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "BROKKR_ENV_FILE=\"$HOME/.config/hydra/dev\" BROKKR_MCP_ENV_NAME=dev BROKKR_MCP_CONFIG_FILE=\"$HOME/.config/brokkr/config.json\" exec \"$HOME/.local/bin/opencode-brokkr-mcp\" dev"
      ],
      "enabled": false
    },
    "brokkr-stg": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "BROKKR_ENV_FILE=\"$HOME/.config/hydra/stg\" BROKKR_MCP_ENV_NAME=stg BROKKR_MCP_CONFIG_FILE=\"$HOME/.config/brokkr/config.json\" exec \"$HOME/.local/bin/opencode-brokkr-mcp\" stg"
      ],
      "enabled": false
    },
    "brokkr-prod": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "BROKKR_ENV_FILE=\"$HOME/.config/hydra/prod\" BROKKR_MCP_ENV_NAME=prod BROKKR_MCP_CONFIG_FILE=\"$HOME/.config/brokkr/config.json\" exec \"$HOME/.local/bin/opencode-brokkr-mcp\" prod"
      ],
      "enabled": false
    },
    "bridge-dev": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "missing=\"\"; for bin in git npm node; do command -v \"$bin\" >/dev/null 2>&1 || missing=\"${missing:+$missing }$bin\"; done; if [ -n \"$missing\" ]; then msg=\"bridge-dev launcher missing dependencies: $missing\"; printf \"%s\\n\" \"$msg\" >&2; exit 127; fi; repo=\"/tmp/opencode/bridge-api-mcp\"; url=\"https://gitlab.com/hydrahost-developers/brokkr-bridge/bridge-api-mcp.git\"; runtime_rev=\"$repo/.mcp-runtime-rev\"; mkdir -p \"$(dirname \"$repo\")\"; if [ ! -d \"$repo/.git\" ]; then git clone --depth 1 --single-branch --filter=blob:none \"$url\" \"$repo\" >/dev/null 2>&1; else git -C \"$repo\" pull --ff-only --quiet >/dev/null 2>&1 || true; fi; head=\"$(git -C \"$repo\" rev-parse HEAD)\"; installed=\"\"; [ -f \"$runtime_rev\" ] && installed=\"$(cat \"$runtime_rev\")\"; if [ ! -f \"$repo/build/index.js\" ] || [ ! -d \"$repo/node_modules\" ] || [ \"$head\" != \"$installed\" ]; then npm --prefix \"$repo\" ci --no-audit --no-fund --quiet >/dev/null 2>&1; npm --prefix \"$repo\" run build >/dev/null 2>&1; printf \"%s\" \"$head\" > \"$runtime_rev\"; fi; exec node \"$repo/build/index.js\""
      ],
      "environment": {
        "BRIDGE_CONFIG": "/tmp/opencode/bridge-api-mcp/configs/dev.yaml"
      },
      "enabled": false
    },
    "bridge-stg": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
