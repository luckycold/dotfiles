{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "kagi-ken": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "czottmann/kagi-ken-mcp"
      ],
      "enabled": true
    },
    "clickup": {
      "type": "remote",
      "url": "https://mcp.clickup.com/mcp",
      "enabled": false
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    },
    "gitlab": {
      "type": "remote",
      "url": "https://gitlab.com/api/v4/mcp",
      "enabled": true
    },
    "pylon": {
      "type": "remote",
      "url": "https://mcp.usepylon.com",
      "enabled": false
    }
  }
}
