{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-openai-codex-auth@4.3.0",
    "opencode-gemini-auth@1.3.6",
    "opencode-scheduler",
    "opencode-smart-voice-notify@latest"
  ],

  "mcp": {
    "kagi-ken": {
      "type": "local",
      "command": ["npx", "-y", "czottmann/kagi-ken-mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "clickup": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.clickup.com/mcp"],
      "enabled": false
    },
    "home-assistant": {
      "type": "remote",
      "url": "https://home.1al.cc/api/mcp",
      "headers": {
        "Authorization": "Bearer {{pass://Main/Home Assistant/MCP API Key}}"
      },
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "gitlab": {
      "type": "remote",
      "url": "https://gitlab.com/api/v4/mcp",
      "enabled": true
    },
    "pylon": {
      "type": "remote",
      "url": "https://mcp.usepylon.com",
      "enabled": false
    },
    "netbox": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "docker image inspect netbox-mcp-server:latest >/dev/null 2>&1 || docker build -t netbox-mcp-server:latest https://github.com/netboxlabs/netbox-mcp-server.git; exec docker run --rm -i -e NETBOX_URL -e NETBOX_TOKEN netbox-mcp-server:latest"
      ],
      "environment": {
        "NETBOX_URL": "https://netbox.prod.hydra.host/"
      },
      "enabled": false
    }
  }
}
