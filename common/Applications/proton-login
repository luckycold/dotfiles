#!/bin/bash

PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"
export PATH

# Function to send native notifications
notify_user() {
    local title="$1"
    local message="$2"
    local urgency="${3:-normal}" # low, normal, critical

    if command -v osascript &>/dev/null; then
        osascript -e "display notification \"$message\" with title \"$title\"" 2>/dev/null
    elif command -v notify-send &>/dev/null; then
        notify-send --urgency="$urgency" "$title" "$message" 2>/dev/null
    fi
}

LOGIN_VERIFY_WAIT_SECONDS="${LOGIN_VERIFY_WAIT_SECONDS:-20}"
KEYRING_WAIT_SECONDS="${KEYRING_WAIT_SECONDS:-90}"
PROTON_LOGIN_NOTIFY_TRANSIENT="${PROTON_LOGIN_NOTIFY_TRANSIENT:-1}"

is_local_db_error() {
    printf '%s\n' "$1" | grep -Eq 'sqlcipher_page_cipher|hmac check failed|Error creating client features|Failed to initialize database|Error decrypting local session|aead::Error|changed your key provider|removed your local key|session has been invalidated'
}

is_already_authenticated() {
    printf '%s\n' "$1" | grep -Eiq 'already authenticated'
}

is_network_error() {
    printf '%s\n' "$1" | grep -Eiq 'timed out|timeout|failed to connect|error resolving|network|connection refused|connection reset|connection aborted|host unreachable|temporarily unavailable'
}

reset_local_session() {
    local data_dir="$HOME/.local/share/proton-pass-cli"
    local session_dir="$data_dir/.session"
    local backup_dir="$data_dir/.session-corrupt-$(date +%Y%m%d-%H%M%S)"

    echo "Resetting local Proton Pass session data..."
    pass-cli logout --force >/dev/null 2>&1 || true

    if [ -e "$session_dir" ]; then
        mv "$session_dir" "$backup_dir"
        echo "Backed up old session data to $backup_dir"
    fi
}

verify_login_ready() {
    local i

    for i in $(seq 1 "$LOGIN_VERIFY_WAIT_SECONDS"); do
        if pass-cli test >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
    done

    return 1
}

lookup_keyring_secret() {
    local secret_type="$1"
    local i value

    for i in $(seq 1 "$KEYRING_WAIT_SECONDS"); do
        value="$(secret-tool lookup service proton-pass type "$secret_type" 2>/dev/null)"
        if [ -n "$value" ]; then
            printf '%s' "$value"
            return 0
        fi

        if [ "$i" -eq 1 ]; then
            echo "Waiting for keyring secret '$secret_type' (up to ${KEYRING_WAIT_SECONDS}s)..."
        fi

        sleep 1
    done

    return 1
}

# Check for required dependencies
for cmd in pass-cli secret-tool; do
    if ! command -v "$cmd" &>/dev/null; then
        msg="Missing dependency: $cmd"
        echo "❌ $msg"
        notify_user "Proton Login Failed" "$msg" "critical"
        exit 1
    fi
done

# 1. Check if we are already logged in
PASS_TEST_OUTPUT="$(pass-cli test 2>&1)"
PASS_TEST_STATUS=$?

if [ "$PASS_TEST_STATUS" -eq 0 ]; then
    echo "✅ Already logged into Proton Pass."
    exit 0
fi

if is_local_db_error "$PASS_TEST_OUTPUT"; then
    reset_local_session
fi

echo "🔄 Session expired or missing. Logging in..."

# 2. Fetch personal access token from keyring
PROTON_PASS_PERSONAL_ACCESS_TOKEN="$(lookup_keyring_secret pat)"

if [ -z "$PROTON_PASS_PERSONAL_ACCESS_TOKEN" ]; then
    msg="PAT missing in keyring. Run: secret-tool store --label='Proton Pass Personal Access Token' service proton-pass type pat"
    echo "❌ $msg"
    notify_user "Proton Login Failed" "Personal access token missing in keyring." "critical"
    exit 5
fi

# 3. Log in with PAT
LOGIN_OUTPUT="$(pass-cli login --pat "$PROTON_PASS_PERSONAL_ACCESS_TOKEN" 2>&1)"
LOGIN_STATUS=$?
unset PROTON_PASS_PERSONAL_ACCESS_TOKEN
printf '%s\n' "$LOGIN_OUTPUT"

if [ "$LOGIN_STATUS" -ne 0 ] && is_local_db_error "$LOGIN_OUTPUT"; then
    reset_local_session
    PROTON_PASS_PERSONAL_ACCESS_TOKEN="$(lookup_keyring_secret pat)"
    LOGIN_OUTPUT="$(pass-cli login --pat "$PROTON_PASS_PERSONAL_ACCESS_TOKEN" 2>&1)"
    LOGIN_STATUS=$?
    unset PROTON_PASS_PERSONAL_ACCESS_TOKEN
    printf '%s\n' "$LOGIN_OUTPUT"
fi

if [ "$LOGIN_STATUS" -ne 0 ]; then
    echo "proton-login exited with status $LOGIN_STATUS"

    if is_already_authenticated "$LOGIN_OUTPUT"; then
        echo "Client is already authenticated but verification failed. Treating as transient connectivity/session verification failure."
        exit 1
    fi

    if is_network_error "$LOGIN_OUTPUT"; then
        echo "Proton Pass login failed due to a transient network/API error. Will retry."
        exit 1
    fi

    echo "Stored Proton Pass personal access token was rejected. Update the keyring PAT before retrying."
    exit 5
fi

if verify_login_ready; then
    echo "✅ Login successful."
else
    msg="Login verification failed. Check connection."
    echo "❌ $msg"
    [ "$PROTON_LOGIN_NOTIFY_TRANSIENT" -eq 1 ] && notify_user "Proton Login Failed" "$msg" "critical"
    exit 1
fi
