#!/bin/bash

PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"
export PATH

# Function to send native notifications
notify_user() {
    local title="$1"
    local message="$2"
    local urgency="${3:-normal}" # low, normal, critical

    if command -v osascript &>/dev/null; then
        osascript -e "display notification \"$message\" with title \"$title\"" 2>/dev/null
    elif command -v notify-send &>/dev/null; then
        notify-send --urgency="$urgency" "$title" "$message" 2>/dev/null
    fi
}

LOGIN_VERIFY_WAIT_SECONDS="${LOGIN_VERIFY_WAIT_SECONDS:-20}"

is_local_db_error() {
    printf '%s\n' "$1" | grep -Eq 'sqlcipher_page_cipher|hmac check failed|Error creating client features|Failed to initialize database'
}

reset_local_session() {
    local data_dir="$HOME/.local/share/proton-pass-cli"
    local session_dir="$data_dir/.session"
    local backup_dir="$data_dir/.session-corrupt-$(date +%Y%m%d-%H%M%S)"

    echo "Resetting local Proton Pass session data..."
    pass-cli logout --force >/dev/null 2>&1 || true

    if [ -e "$session_dir" ]; then
        mv "$session_dir" "$backup_dir"
        echo "Backed up old session data to $backup_dir"
    fi
}

verify_login_ready() {
    local i

    for i in $(seq 1 "$LOGIN_VERIFY_WAIT_SECONDS"); do
        if pass-cli test >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
    done

    return 1
}

# Check for required dependencies
for cmd in pass-cli secret-tool oathtool; do
    if ! command -v "$cmd" &>/dev/null; then
        msg="Missing dependency: $cmd"
        echo "❌ $msg"
        notify_user "Proton Login Failed" "$msg" "critical"
        exit 1
    fi
done

# 1. Check if we are already logged in
PASS_TEST_OUTPUT="$(pass-cli test 2>&1)"
PASS_TEST_STATUS=$?

if [ "$PASS_TEST_STATUS" -eq 0 ]; then
    echo "✅ Already logged into Proton Pass."
    exit 0
fi

if is_local_db_error "$PASS_TEST_OUTPUT"; then
    reset_local_session
fi

echo "🔄 Session expired or missing. Logging in..."

# 2. Fetch Password from keyring
export PROTON_PASS_PASSWORD="$(secret-tool lookup service proton-pass type password)"

if [ -z "$PROTON_PASS_PASSWORD" ]; then
    msg="Password missing in keyring. Run: secret-tool store --label='Proton Pass Password' service proton-pass type password"
    echo "❌ $msg"
    notify_user "Proton Login Failed" "Password missing in keyring." "critical"
    exit 1
fi

# 3. Fetch TOTP Secret and generate code
TOTP_SECRET="$(secret-tool lookup service proton-pass type totp)"

if [ -z "$TOTP_SECRET" ]; then
    msg="TOTP secret missing in keyring. Run: secret-tool store --label='Proton Pass TOTP' service proton-pass type totp"
    echo "❌ $msg"
    notify_user "Proton Login Failed" "TOTP secret missing in keyring." "critical"
    exit 1
fi

# oathtool: --totp for time-based, -b for base32 input
export PROTON_PASS_TOTP="$(oathtool --totp -b "$TOTP_SECRET")"

# 4. Log in
LOGIN_OUTPUT="$(pass-cli login --interactive hello@lukewilliams.org 2>&1)"
LOGIN_STATUS=$?
printf '%s\n' "$LOGIN_OUTPUT"

if [ "$LOGIN_STATUS" -ne 0 ] && is_local_db_error "$LOGIN_OUTPUT"; then
    reset_local_session
    LOGIN_OUTPUT="$(pass-cli login --interactive hello@lukewilliams.org 2>&1)"
    LOGIN_STATUS=$?
    printf '%s\n' "$LOGIN_OUTPUT"
fi

if [ "$LOGIN_STATUS" -ne 0 ]; then
    echo "proton-login exited with status $LOGIN_STATUS"
fi

if verify_login_ready; then
    echo "✅ Login successful."
else
    msg="Login failed. Check connection or credentials."
    echo "❌ $msg"
    notify_user "Proton Login Failed" "$msg" "critical"
    exit 1
fi

# 5. Cleanup variables
unset PROTON_PASS_PASSWORD
unset PROTON_PASS_TOTP
