#!/bin/bash

PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"
export PATH

secret_type="$1"

case "$secret_type" in
pat)
  label="Proton Pass Personal Access Token"
  prompt="Enter the Proton Pass personal access token to store in your keyring."
  ;;
password)
  label="Proton Pass Password"
  prompt="Enter the Proton Pass password to store in your keyring."
  ;;
extra-password)
  label="Proton Pass Extra Password"
  prompt="Enter the Proton Pass extra password to store in your keyring."
  ;;
totp)
  label="Proton Pass TOTP"
  prompt="Enter the Proton Pass TOTP seed to store in your keyring."
  ;;
*)
  printf 'Usage: %s pat|password|extra-password|totp\n' "$0" >&2
  exit 64
  ;;
esac

notify_user() {
  local title="$1" message="$2" urgency="${3:-normal}"
  command -v notify-send >/dev/null 2>&1 && notify-send --urgency="$urgency" "$title" "$message" 2>/dev/null || true
}

prompt_secret() {
  if command -v zenity >/dev/null 2>&1; then
    if [ "$secret_type" = pat ] || [ "$secret_type" = password ] || [ "$secret_type" = extra-password ]; then
      zenity --password --title="$label" 2>/dev/null
    else
      zenity --entry --title="$label" --text="$prompt" --hide-text 2>/dev/null
    fi
    return
  fi

  if command -v xdg-terminal-exec >/dev/null 2>&1; then
    xdg-terminal-exec bash -lc "read -rsp '$prompt ' value; printf '\n'; [ -n \"\$value\" ] && secret-tool clear service proton-pass type '$secret_type' >/dev/null 2>&1 || true; [ -n \"\$value\" ] && printf '%s' \"\$value\" | secret-tool store --label='$label' service proton-pass type '$secret_type'; systemctl --user restart proton-pass-cli-autologin.service; read -rp 'Press Enter to close...'" &
    exit 0
  fi

  return 1
}

if ! command -v secret-tool >/dev/null 2>&1; then
  notify_user "Proton Pass" "secret-tool is not installed." critical
  exit 1
fi

value="$(prompt_secret)" || {
  notify_user "Proton Pass" "No graphical secret prompt available." critical
  exit 1
}

if [ -z "$value" ]; then
  notify_user "Proton Pass" "Secret update cancelled."
  exit 0
fi

secret-tool clear service proton-pass type "$secret_type" >/dev/null 2>&1 || true
printf '%s' "$value" | secret-tool store --label="$label" service proton-pass type "$secret_type"
unset value

notify_user "Proton Pass" "$label updated. Restarting login service."
systemctl --user restart proton-pass-cli-autologin.service
