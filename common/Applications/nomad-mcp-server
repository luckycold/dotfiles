#!/usr/bin/env bash
set -euo pipefail

version="${NOMAD_MCP_VERSION:-0.2.8}"
cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/nomad-mcp/$version"
token_helper="${NOMAD_MCP_TOKEN_HELPER:-$HOME/Applications/nomad-mcp-token}"

require_bin() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$1" >&2
    exit 127
  fi
}

platform_package() {
  local os arch

  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m)"

  case "$os" in
    linux|freebsd|darwin)
      ;;
    *)
      printf 'Unsupported operating system: %s\n' "$os" >&2
      exit 1
      ;;
  esac

  case "$arch" in
    x86_64|amd64)
      arch="x64"
      ;;
    aarch64|arm64)
      arch="arm64"
      ;;
    *)
      printf 'Unsupported architecture: %s\n' "$arch" >&2
      exit 1
      ;;
  esac

  printf '@kocierik/mcp-nomad-%s-%s' "$os" "$arch"
}

install_server() {
  mkdir -p "$cache_root"

  npm install \
    --prefix "$cache_root" \
    --no-save \
    --no-audit \
    --no-fund \
    --silent \
    "@kocierik/mcp-nomad@$version" \
    >/dev/null
}

require_bin npm

if [ ! -x "$token_helper" ]; then
  printf 'Missing Nomad token helper: %s\n' "$token_helper" >&2
  exit 127
fi

package_name="$(platform_package)"
binary="$cache_root/node_modules/$package_name/bin/mcp-nomad"

if [ ! -x "$binary" ]; then
  install_server
fi

if [ ! -x "$binary" ]; then
  printf 'Nomad MCP binary not found after install: %s\n' "$binary" >&2
  exit 1
fi

token="${NOMAD_TOKEN:-}"
if [ -z "$token" ]; then
  token="$($token_helper)"
fi

export NOMAD_TOKEN="$token"
exec "$binary" -transport=stdio "$@"
