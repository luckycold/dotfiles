#!/usr/bin/env bash
set -euo pipefail

nomad_addr="${NOMAD_ADDR:-https://nomad.prod.hydra.host}"
nomad_auth_method="${NOMAD_AUTH_METHOD:-}"
state_root="${XDG_STATE_HOME:-$HOME/.local/state}"
cache_key="$(printf '%s__%s' "$nomad_addr" "$nomad_auth_method" | tr -cs 'A-Za-z0-9._-' '_')"
token_file="${NOMAD_MCP_TOKEN_FILE:-$state_root/nomad-mcp/${cache_key}.token}"

usage() {
  cat >&2 <<EOF
Usage: nomad-mcp-token [refresh|clear]

Without arguments, prints a cached Nomad token if it is still valid.

Commands:
  refresh  Run OIDC login, validate the token, and cache it
  clear    Delete the cached token
EOF
}

require_bin() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$1" >&2
    exit 127
  fi
}

validate_token() {
  local token

  token="${1:-}"
  [ -n "$token" ] || return 1

  nomad acl token self \
    -address "$nomad_addr" \
    -token "$token" \
    >/dev/null 2>&1
}

read_token() {
  local token

  if [ ! -f "$token_file" ]; then
    return 1
  fi

  IFS= read -r token <"$token_file" || token=""
  [ -n "$token" ] || return 1
  printf '%s\n' "$token"
}

refresh_token() {
  local tmp token line

  mkdir -p "$(dirname "$token_file")"
  chmod 700 "$(dirname "$token_file")" 2>/dev/null || true

  tmp="$(mktemp)"
  trap "rm -f \"$tmp\"" EXIT

  if [ -n "$nomad_auth_method" ]; then
    if ! nomad login \
      -address "$nomad_addr" \
      -method "$nomad_auth_method" \
      -t '{{ .SecretID }}' \
      >"$tmp"; then
      printf 'Nomad login failed for %s using %s\n' "$nomad_addr" "$nomad_auth_method" >&2
      exit 1
    fi
  elif ! nomad login \
    -address "$nomad_addr" \
    -t '{{ .SecretID }}' \
    >"$tmp"; then
    printf 'Nomad login failed for %s using the cluster default auth method\n' "$nomad_addr" >&2
    exit 1
  fi

  token=""
  while IFS= read -r line || [ -n "$line" ]; do
    if [ -n "$line" ]; then
      token="$line"
    fi
  done <"$tmp"

  if ! validate_token "$token"; then
    if [ -n "$nomad_auth_method" ]; then
      printf 'Failed to capture a valid Nomad token. Run `nomad login -address %s -method %s` manually if you need to inspect the OIDC flow.\n' "$nomad_addr" "$nomad_auth_method" >&2
    else
      printf 'Failed to capture a valid Nomad token. Run `nomad login -address %s` manually if you need to inspect the OIDC flow.\n' "$nomad_addr" >&2
    fi
    exit 1
  fi

  umask 077
  printf '%s\n' "$token" >"$token_file"
  printf '%s\n' "$token"
  trap - EXIT
  rm -f "$tmp"
}

print_token() {
  local token

  if ! token="$(read_token)"; then
    printf 'No cached Nomad token. Run `%s refresh` first.\n' "$0" >&2
    exit 1
  fi

  if ! validate_token "$token"; then
    printf 'Cached Nomad token is expired or invalid. Run `%s refresh`.\n' "$0" >&2
    exit 1
  fi

  printf '%s\n' "$token"
}

clear_token() {
  rm -f "$token_file"
}

require_bin nomad

case "${1:-}" in
  "")
    print_token
    ;;
  refresh)
    refresh_token
    ;;
  clear)
    clear_token
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
