#!/usr/bin/env python3

import json
import subprocess
import sys
import threading


def patch_tools_message(message):
    result = message.get("result")
    if not isinstance(result, dict):
        return message

    tools = result.get("tools")
    if not isinstance(tools, list):
        return message

    for tool in tools:
        if not isinstance(tool, dict) or tool.get("name") != "create_acl_token":
            continue

        input_schema = tool.get("inputSchema")
        if not isinstance(input_schema, dict):
            continue

        properties = input_schema.get("properties")
        if not isinstance(properties, dict):
            continue

        policies = properties.get("policies")
        if not isinstance(policies, dict):
            continue

        if policies.get("type") == "array" and "items" not in policies:
            policies["items"] = {"type": "string"}

    return message


def main():
    if len(sys.argv) < 2:
        print("Usage: nomad-mcp-stdio-proxy <binary> [args...]", file=sys.stderr)
        raise SystemExit(2)

    binary = sys.argv[1]
    args = [binary, "-transport=stdio", *sys.argv[2:]]

    proc = subprocess.Popen(
        args,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=sys.stderr,
        text=True,
        bufsize=1,
    )

    def forward_stdin():
        try:
            for line in sys.stdin:
                if proc.stdin is None:
                    return
                proc.stdin.write(line)
                proc.stdin.flush()
        finally:
            if proc.stdin is not None:
                proc.stdin.close()

    threading.Thread(target=forward_stdin, daemon=True).start()

    for line in proc.stdout:
        try:
            message = json.loads(line)
        except json.JSONDecodeError:
            sys.stdout.write(line)
            sys.stdout.flush()
            continue

        patched = patch_tools_message(message)
        sys.stdout.write(json.dumps(patched, separators=(",", ":")) + "\n")
        sys.stdout.flush()

    raise SystemExit(proc.wait())


if __name__ == "__main__":
    main()
